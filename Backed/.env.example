# ===================== 数据库配置 =====================
# 数据库连接地址
# 格式：mysql+pymysql://用户名:密码@数据库地址:端口/数据库名
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/eating

# ===================== JWT认证配置 =====================
# JWT密钥（生产环境必须修改！用于登录token加密）
SECRET_KEY=your-secret-key-change-in-production
# JWT加密算法（固定使用HS256）
ALGORITHM=HS256
# 登录令牌有效期：1440分钟 = 24小时（一天免登录）
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===================== 系统内置0级管理员 =====================
# 0级超级管理员账户（唯一内置，不可删除，最高权限）
ADMIN_0_ACCOUNT=a7s90001
# 0级管理员初始密码（首次登录后必须修改）
ADMIN_0_PASSWORD=your_initial_password