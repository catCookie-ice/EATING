# ===================== 数据库配置 =====================
# 数据库连接地址
# 格式：mysql+pymysql://用户名:密码@数据库地址:端口/数据库名
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/eating

# ===================== JWT认证配置 =====================
# JWT密钥（生产环境必须修改！用于登录token加密）
SECRET_KEY=your-secret-key-change-in-production
# JWT加密算法（固定使用HS256）
ALGORITHM=HS256
# 登录令牌有效期：1440分钟 = 24小时（一天免登录）
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===================== 系统内置0级管理员 =====================
# 0级超级管理员账户（唯一内置，不可删除，最高权限）
ADMIN_0_ACCOUNT=a7s90001
# 0级管理员初始密码（首次登录后必须修改）
ADMIN_0_PASSWORD=your_initial_password

# ===================== 存储配置 =====================
# 存储类型：cloud(云存储) / local(本地存储) / mixed(混合存储)
STORAGE_TYPE=local

# 腾讯云COS配置（云存储或混合存储时需要配置）
COS_SECRET_ID=your-secret-id
COS_SECRET_KEY=your-secret-key
COS_BUCKET=your-bucket-name
COS_REGION=ap-guangzhou
# 云存储URL过期时间(秒)，默认3600秒
COS_URL_EXPIRE_SECONDS=3600

# 本地存储配置
# 本地上传目录（相对于项目根目录）
LOCAL_UPLOAD_DIR=uploads
# 本地存储基础URL
LOCAL_BASE_URL=/uploads

# ===================== DeepSeek AI 配置 =====================
# DeepSeek API 密钥（从 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=your-deepseek-api-key
# 使用的模型，默认 deepseek-chat
DEEPSEEK_MODEL=deepseek-chat